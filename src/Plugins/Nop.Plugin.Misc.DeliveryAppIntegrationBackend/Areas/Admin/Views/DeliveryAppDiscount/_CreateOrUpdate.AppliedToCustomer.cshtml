@model DeliveryAppDiscountModel
@{

    var gridPageSize = 5;
}

@if (Model.Id > 0)
{
    <div class="panel-body">
        @await Html.PartialAsync("Table", new DataTablesModel
    {
       Name = "customer-discount-grid",
       UrlRead = new DataUrl("GetCustomerCustomDiscount", "DeliveryAppDiscount", new RouteValueDictionary { [nameof(Model.DiscountProductSearchModel.DiscountId)] = Model.DiscountProductSearchModel.DiscountId }),
       UrlDelete = new DataUrl("CustomerDelete", "DeliveryAppDiscount", new RouteValueDictionary { [nameof(Model.DiscountProductSearchModel.DiscountId)] = Model.DiscountProductSearchModel.DiscountId }),
       BindColumnNameActionDelete = nameof(DeliveryAppCustomerCustomDiscountModel.CustomerId),
       Length = gridPageSize,
       ColumnCollection = new List<ColumnProperty>
            {
                new ColumnProperty(nameof(DeliveryAppCustomerCustomDiscountModel.CustomerName))
                {
                    Title = T("Admin.Customers.CustomerAttributes.Fields.Name").Text,
                    Width = "150"
                },
                new ColumnProperty(nameof(DeliveryAppCustomerCustomDiscountModel.DiscountName))
                {
                    Title = T("Admin.Promotions.Discounts.Fields.Name").Text,
                    Width = "80",
                },
                new ColumnProperty(nameof(DeliveryAppCustomerCustomDiscountModel.DiscountAmount))
                {
                    Title = T("Admin.Promotions.Discounts.Fields.Discount").Text,
                    Width = "80",
                },
                new ColumnProperty(nameof(DeliveryAppCustomerCustomDiscountModel.CustomerId))
                {
                    Title = T("Admin.Common.Delete").Text,
                    Width = "150",
                    Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                    ClassName =  NopColumnClassDefaults.Button
                }
            }
    })
    </div>

    <div class="panel-footer">
        <button type="submit" id="btnAddNewCustomer" onclick="javascript:OpenWindow('@(Url.Action("CustomerAddPopUp", "DeliveryAppDiscount", new { discountId = Model.Id, btnId = "btnRefreshCustomers", formId = "discount-form" }))', 800, 800, true); return false;" class="btn btn-primary">
            @T("Admin.Promotions.Discounts.AppliedToCustomers.AddNew")
        </button>
        <input type="submit" id="btnRefreshCustomers" style="display: none" />
        <script>
            $(document).ready(function () {
                $('#btnRefreshCustomers').click(function () {
                    updateTable('#customer-discount-grid');
                    return false;
                });
            });
        </script>
    </div>
}
else
{
    <div class="panel-body">
        @T("Admin.Promotions.Discounts.AppliedToProducts.SaveBeforeEdit")
    </div>
}
