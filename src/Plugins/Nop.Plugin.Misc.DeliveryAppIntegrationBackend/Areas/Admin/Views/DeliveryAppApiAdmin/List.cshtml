    <input type="hidden" id="selectedIds" name="selectedIds" value="" />
</form>

@*Pay to vendors selected orders payment.*@
<form asp-controller="DeliveryAppApiAdmin" asp-action="MarkGroupOrderVendorAsPaid" method="post" id="collect-vendor-payment-selected-form">
    <input type="hidden" id="selectedIds" name="selectedIds" value="" />
</form>

<script>
    $(document).ready(function () {
        $('#paytodrivers-selected').click(function (e) {
            e.preventDefault();
            var ids = selectedIds.join(",");
            if (ids) {
                $('#collect-driver-payment-selected-form #selectedIds').val(ids);
                $('#collect-driver-payment-selected-form').submit();
                updateTable('#orders-grid');
            }
            else {
                $('#collectPaymentSelected-info').text("@T("Admin.Orders.NoOrders")");
                $("#collectPaymentSelected").click();
            }
            return false;
        });

        $('#paytovendors-selected').click(function (e) {
            e.preventDefault();
            var ids = selectedIds.join(",");
            if (ids) {
                $('#collect-vendor-payment-selected-form #selectedIds').val(ids);
                $('#collect-vendor-payment-selected-form').submit();
                updateTable('#orders-grid');
            }
            else {
                $('#collectPaymentSelected-info').text("@T("Admin.Orders.NoOrders")");
                $("#collectPaymentSelected").click();
            }
            return false;
        });
    });
</script>
<nop-alert asp-alert-id="collectPaymentSelected" />