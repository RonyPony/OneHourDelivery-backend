@model Nop.Plugin.Synchronizers.ASAP.Models.DeliveryAsapConfigurationModel

@{
    Layout = "_ConfigurePlugin";
}

@await Component.InvokeAsync("StoreScopeConfiguration")
@await Component.InvokeAsync("SettingMode")

<form asp-controller="AsapDelivery" asp-action="Configure" method="post">
    <div class="panel-group">
        <div class="panel panel-default">
            <div class="panel-body">
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="ServiceUrl" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="ServiceUrl" asp-required="true" asp-value="@Model.ServiceUrl" />
                        <span asp-validation-for="ServiceUrl"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="ApiKey" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="ApiKey" asp-required="true" asp-value="@Model.ApiKey" />
                        <span asp-validation-for="ApiKey"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="UserToken" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="UserToken" asp-required="true" asp-value="@Model.UserToken" />
                        <span asp-validation-for="UserToken"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="SharedSecret" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="SharedSecret" asp-required="true" asp-value="@Model.SharedSecret" />
                        <span asp-validation-for="SharedSecret"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="Email" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="Email" asp-required="true" asp-value="@Model.Email" />
                        <span asp-validation-for="Email"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="Rate" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="Rate" asp-value="@Model.Rate" />
                        <nop-required />
                        <span asp-validation-for="Rate"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="Description" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="Description" asp-value="@Model.Description" />
                        <span asp-validation-for="Description"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="DefaultWarehouseId" asp-postfix=":"></nop-label>
                    </div>
                    <div class="inputs">
                        <div class="col-md-9">
                            <nop-select asp-for="DefaultWarehouseId" asp-required="true" asp-items="Model.Warehouses"></nop-select>
                            <span asp-validation-for="DefaultWarehouseId"></span>
                        </div>
                    </div>
                </div>
                <div class="form-group"></div>
                <div class="form-group">
                    <div class="col-md-9 col-md-offset-3">
                        <input type="submit" name="save" class="btn btn-primary" value="@T("Admin.Common.Save")" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>