@model ZoomPluginConfigurationModel
@{
    Layout = "_ConfigurePlugin";
}

<form asp-controller="ZoomWidget" asp-action="Configure" method="post">
    <div class="panel-group">
        <div class="panel panel-default">
            <div class="panel-body">
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="ZoomEnabled" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="ZoomEnabled" />
                        <span asp-validation-for="ZoomEnabled"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="PicturesMobileCarouselEnabled" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="PicturesMobileCarouselEnabled" />
                        <span asp-validation-for="PicturesMobileCarouselEnabled"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="ChangeMainPictureOnThumbsHoverEnabled" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="ChangeMainPictureOnThumbsHoverEnabled" />
                        <span asp-validation-for="ChangeMainPictureOnThumbsHoverEnabled"></span>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="PictureThumbsLocationId" asp-postfix=":"></nop-label>
                    </div>
                    <div class="inputs">
                        <div class="col-md-9">
                            <nop-select asp-for="PictureThumbsLocationId" asp-items="Model.AvailableThumbsLocation"></nop-select>
                            <span asp-validation-for="PictureThumbsLocationId"></span>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-9 col-md-offset-3">
                        <input type="submit" name="save" class="btn bg-primary" value="@T("Admin.Common.Save")" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>