@model DeliveryAppBackendConfigurationModel
@{
    Layout = "_ConfigurePlugin";
}
@await Component.InvokeAsync("StoreScopeConfiguration")
@await Component.InvokeAsync("SettingMode")

<form asp-controller="DeliveryAppIntegration" asp-action="Configure" method="post">
    <div class="panel-group">
        <nop-panel asp-name="delivery-app-payment" asp-icon="fa fa-credit-card" asp-title="@T($"{Defaults.LocaleResourcesPrefix}.Payment.Config.Panel.Title")" asp-hide-block-attribute-name="false" asp-hide="false" asp-advanced="false">
            <div class="panel-body">

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="PaymentPageUrl" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="PaymentPageUrl" asp-required="true" />
                        <span asp-validation-for="PaymentPageUrl"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="RedirectUrl" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="RedirectUrl" asp-required="true" />
                        <span asp-validation-for="RedirectUrl"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="AccessKey" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="AccessKey" asp-required="true" />
                        <span asp-validation-for="AccessKey"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="MerchantId" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="MerchantId" asp-required="true" />
                        <span asp-validation-for="MerchantId"></span>
                    </div>
                </div>
                
                                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="NotificationCenterUrl" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="NotificationCenterUrl" asp-required="true" />
                        <span asp-validation-for="NotificationCenterUrl"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="NotificationDriverTrackingUrl" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="NotificationDriverTrackingUrl" asp-required="true" />
                        <span asp-validation-for="NotificationDriverTrackingUrl"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="SecretKey" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="SecretKey" asp-required="true" />
                        <span asp-validation-for="SecretKey"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="ProfileId" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="ProfileId" asp-required="true" />
                        <span asp-validation-for="ProfileId"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="TransactionType" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="TransactionType" asp-required="true" />
                        <span asp-validation-for="TransactionType"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="Currency" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="Currency" asp-required="true" />
                        <span asp-validation-for="Currency"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="Locale" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="Locale" asp-required="true" />
                        <span asp-validation-for="Locale"></span>
                    </div>
                </div>

               <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="MessengerProfit" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="MessengerProfit" />
                        <span asp-validation-for="MessengerProfit"></span>
                    </div>
                </div>
                
                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="AdditionalFee" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="AdditionalFee" />
                        <span asp-validation-for="AdditionalFee"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="MaxMoneyAmountDriverCanCarry" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="MaxMoneyAmountDriverCanCarry" />
                        <span asp-validation-for="MaxMoneyAmountDriverCanCarry"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        <nop-label asp-for="AdministrativeProfit" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="AdministrativeProfit" />
                        <span asp-validation-for="AdministrativeProfit"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-3">
                        &nbsp;
                    </div>
                    <div class="col-md-9">
                        <input type="submit" name="save" class="btn bg-blue" value="@T("Admin.Common.Save")" />
                    </div>
                </div>

            </div>
        </nop-panel>
    </div>
</form>
