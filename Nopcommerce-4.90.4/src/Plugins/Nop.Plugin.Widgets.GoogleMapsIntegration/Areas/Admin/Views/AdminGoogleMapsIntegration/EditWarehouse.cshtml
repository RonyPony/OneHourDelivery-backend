@model CustomWarehouseEditModel

@using Nop.Web.Framework.Infrastructure
@using Nop.Web.Framework.UI

@inject INopHtmlHelper NopHtml

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    ViewBag.PageTitle = T("Admin.Configuration.Shipping.Warehouses.EditWarehouseDetails").Text;

    NopHtml.SetActiveMenuItemSystemName("Warehouses");
}

<form asp-controller="AdminGoogleMapsIntegration" asp-action="EditWarehouse" method="post">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T("Admin.Configuration.Shipping.Warehouses.EditWarehouseDetails") - @Model.WarehouseModel.Name
            <small>
                <i class="fas fa-arrow-circle-left"></i>
                <a asp-controller="Shipping" asp-action="Warehouses">@T("Admin.Configuration.Shipping.Warehouses.BackToList")</a>
            </small>
        </h1>
        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">
                <i class="far fa-save"></i>
                @T("Admin.Common.Save")
            </button>
            <button type="submit" name="save-continue" class="btn btn-primary">
                <i class="far fa-save"></i>
                @T("Admin.Common.SaveContinue")
            </button>
            <span id="warehouse-delete" class="btn btn-danger">
                <i class="far fa-trash-alt"></i>
                @T("Admin.Common.Delete")
            </span>
            @await Component.InvokeAsync("AdminWidget", new { widgetZone = AdminWidgetZones.WarehouseDetailsButtons, additionalData = Model.WarehouseModel })
        </div>
    </div>

    @await Html.PartialAsync("_CreateOrUpdateWarehouse", Model)
</form>

<nop-delete-confirmation asp-model-id="@Model.WarehouseModel.Id" asp-button-id="warehouse-delete" asp-action="DeleteWarehouse" />